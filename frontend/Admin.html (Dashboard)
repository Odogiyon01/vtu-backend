<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <h1>Admin Dashboard</h1>

  <div id="tabs">
    <button onclick="showTab('users')">Users</button>
    <button onclick="showTab('transactions')">Transactions</button>
    <button onclick="showTab('prices')">Edit Prices</button>
    <button onclick="showTab('refund')">Refund/Adjust</button>
  </div>

  <div id="content">
    <div id="users" class="tab">
      <h2>All Users</h2>
      <table id="userTable"></table>
    </div>

    <div id="transactions" class="tab" style="display:none">
      <h2>Transactions</h2>
      <table id="transactionTable"></table>
    </div>

    <div id="prices" class="tab" style="display:none">
      <h2>Edit Prices</h2>
      <form onsubmit="updatePrices(event)">
        <label>Airtime Profit %</label>
        <input type="number" id="airtimeMargin" required>
        <label>Data Profit %</label>
        <input type="number" id="dataMargin" required>
        <button type="submit">Save</button>
      </form>
    </div>

    <div id="refund" class="tab" style="display:none">
      <h2>Refund/Adjust User Balance</h2>
      <form onsubmit="refundUser(event)">
        <input type="text" id="userId" placeholder="User ID" required>
        <input type="number" id="amount" placeholder="Amount (+/-)" required>
        <button type="submit">Update</button>
      </form>
    </div>
  </div>

  <script src="js/admin.js"></script>
</body>
</html>

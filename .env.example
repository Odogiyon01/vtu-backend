# Render → Environment → add these (DO NOT commit real values)
PORT=3000
SMEPLUG_SECRET_KEY=your_smeplug_secret_key_here
OPAY_SECRET_KEY=your_opay_secret_key_here

# Firebase service account fields
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
# paste private key with \n for newlines
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
